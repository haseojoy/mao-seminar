# ============================================================
# 家計管理アプリ 環境変数設定
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# ============================================================

# ----------------------------------------
# Anthropic / Claude API
# https://console.anthropic.com/ で取得
# ----------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ----------------------------------------
# りそな銀行 Open Banking API
# https://developer.resona-gr.co.jp/ で登録
# ----------------------------------------
RISONA_CLIENT_ID=your_risona_client_id
RISONA_CLIENT_SECRET=your_risona_client_secret
RISONA_REFRESH_TOKEN=your_risona_refresh_token

# ----------------------------------------
# クレジットカード API
# CC_PROVIDER: smbc / rakuten / jcb
# ----------------------------------------
CC_PROVIDER=smbc
CC_CLIENT_ID=your_cc_client_id
CC_CLIENT_SECRET=your_cc_client_secret
CC_REFRESH_TOKEN=your_cc_refresh_token

# ----------------------------------------
# 出力設定
# ----------------------------------------
OUTPUT_DIR=output

# ----------------------------------------
# 貯蓄目標設定
# ----------------------------------------
GOAL_TARGET=1000000       # メイン目標: 100万円
GOAL_STRETCH=1500000      # ストレッチ目標: 150万円
GOAL_DEADLINE=2026-12-31  # 達成期限
CURRENT_SAVINGS=0         # 現在の累計貯蓄額（毎月更新）
